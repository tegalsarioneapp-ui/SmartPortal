{
  "outputDirectory": "dist",
  "buildCommand": "cp index.html dist/index.html && cp -r public/. dist/",
  "installCommand": "mkdir -p dist && echo skip",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://smartportal-production.up.railway.app/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}