{
  "outputDirectory": "dist",
  "buildCommand": "mkdir -p dist && cp index.html dist/index.html && cp -r public/. dist/",
  "installCommand": "echo skip",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://smartportal-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}